{
  "$ref": "#/$defs/Schema",
  "$defs": {
    "Schema": {
      "type": "object",
      "properties": {
        "玩家": {
          "$ref": "#/$defs/玩家"
        },
        "任务": {
          "$ref": "#/$defs/任务"
        },
        "世界": {
          "$ref": "#/$defs/世界"
        },
        "战斗": {
          "$ref": "#/$defs/战斗"
        },
        "进度": {
          "$ref": "#/$defs/进度"
        }
      },
      "required": ["玩家", "任务", "世界", "战斗", "进度"]
    },
    "玩家": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string",
          "default": "冒险者"
        },
        "基础属性": {
          "$ref": "#/$defs/基础属性"
        },
        "等级": {
          "enum": ["F级", "E级", "D级", "C级", "B级", "A级", "S级", "SS级", "SSS级"],
          "default": "F级"
        },
        "沉淀点": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "战斗属性": {
          "$ref": "#/$defs/战斗属性"
        },
        "状态": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/状态效果"
          },
          "default": []
        },
        "种族": {
          "type": "string",
          "default": "人类"
        },
        "血脉": {
          "type": "string",
          "default": "无"
        },
        "性格特征": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/性格特征"
          },
          "default": []
        },
        "技能": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/技能"
          },
          "default": []
        },
        "装备": {
          "$ref": "#/$defs/装备"
        },
        "物品栏": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/物品"
          },
          "default": {}
        },
        "兑换点": {
          "type": "number",
          "minimum": 0,
          "default": 100
        },
        "位置": {
          "type": "string",
          "default": "乾坤界"
        }
      },
      "required": [
        "名称",
        "基础属性",
        "等级",
        "沉淀点",
        "战斗属性",
        "状态",
        "种族",
        "血脉",
        "性格特征",
        "技能",
        "装备",
        "物品栏",
        "兑换点",
        "位置"
      ]
    },
    "基础属性": {
      "type": "object",
      "properties": {
        "力量": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        },
        "敏捷": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        },
        "体质": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        },
        "智力": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        },
        "感知": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        },
        "魅力": {
          "type": "number",
          "minimum": 5,
          "maximum": 30,
          "default": 10
        }
      },
      "required": ["力量", "敏捷", "体质", "智力", "感知", "魅力"]
    },
    "战斗属性": {
      "type": "object",
      "properties": {
        "HP": {
          "type": "object",
          "properties": {
            "当前": {
              "type": "number",
              "default": 50
            },
            "最大": {
              "type": "number",
              "default": 50
            }
          },
          "required": ["当前", "最大"]
        },
        "护盾": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "物理攻击": {
          "type": "number",
          "default": 10
        },
        "法术攻击": {
          "type": "number",
          "default": 10
        },
        "物理防御": {
          "type": "number",
          "default": 10
        },
        "法术防御": {
          "type": "number",
          "default": 10
        },
        "DDC": {
          "type": "number",
          "default": 10
        },
        "暴击率": {
          "type": "number",
          "minimum": 0,
          "maximum": 50,
          "default": 10
        }
      },
      "required": ["HP", "护盾", "物理攻击", "法术攻击", "物理防御", "法术防御", "DDC", "暴击率"]
    },
    "状态效果": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "效果": {
          "type": "string"
        },
        "剩余回合": {
          "type": "number",
          "minimum": 0,
          "default": 1
        }
      },
      "required": ["名称", "效果", "剩余回合"]
    },
    "性格特征": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "效果": {
          "type": "string"
        }
      },
      "required": ["名称", "效果"]
    },
    "技能": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "等级": {
          "enum": ["F级", "E级", "D级", "C级", "B级", "A级", "S级"],
          "default": "F级"
        },
        "类型": {
          "enum": ["主动", "被动", "其他"],
          "default": "主动"
        },
        "冷却": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "当前冷却": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "效果": {
          "type": "string"
        },
        "词条": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["名称", "等级", "类型", "冷却", "当前冷却", "效果", "词条"]
    },
    "装备": {
      "type": "object",
      "properties": {
        "武器": {
          "$ref": "#/$defs/武器"
        },
        "防具": {
          "$ref": "#/$defs/防具"
        },
        "饰品": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/饰品"
          },
          "default": []
        }
      },
      "required": ["武器", "防具", "饰品"]
    },
    "武器": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string",
          "default": ""
        },
        "等级": {
          "enum": ["", "F级", "E级", "D级", "C级", "B级", "A级", "S级"],
          "default": ""
        },
        "物伤加成": {
          "type": "number",
          "default": 0
        },
        "法伤加成": {
          "type": "number",
          "default": 0
        }
      },
      "required": ["名称", "等级", "物伤加成", "法伤加成"]
    },
    "防具": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string",
          "default": ""
        },
        "等级": {
          "enum": ["", "F级", "E级", "D级", "C级", "B级", "A级", "S级"],
          "default": ""
        },
        "物防加成": {
          "type": "number",
          "default": 0
        },
        "法防加成": {
          "type": "number",
          "default": 0
        },
        "HP加成": {
          "type": "number",
          "default": 0
        }
      },
      "required": ["名称", "等级", "物防加成", "法防加成", "HP加成"]
    },
    "饰品": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "效果": {
          "type": "string"
        }
      },
      "required": ["名称", "效果"]
    },
    "物品": {
      "type": "object",
      "properties": {
        "描述": {
          "type": "string"
        },
        "数量": {
          "type": "number",
          "minimum": 0,
          "default": 1
        },
        "类型": {
          "enum": ["消耗品", "材料", "任务道具", "特殊"],
          "default": "消耗品"
        }
      },
      "required": ["描述", "数量", "类型"]
    },
    "任务": {
      "type": "object",
      "properties": {
        "主线": {
          "$ref": "#/$defs/主线任务"
        },
        "支线": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/支线任务"
          },
          "default": []
        }
      },
      "required": ["主线", "支线"]
    },
    "主线任务": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string",
          "default": ""
        },
        "完成度": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0
        },
        "描述": {
          "type": "string",
          "default": ""
        }
      },
      "required": ["名称", "完成度", "描述"]
    },
    "支线任务": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "完成度": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0
        },
        "描述": {
          "type": "string"
        }
      },
      "required": ["名称", "完成度", "描述"]
    },
    "世界": {
      "type": "object",
      "properties": {
        "当前场景": {
          "type": "string",
          "default": "乾坤界"
        },
        "当前世界": {
          "$ref": "#/$defs/当前世界"
        },
        "关键NPC": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NPC"
          },
          "default": []
        },
        "战斗状态": {
          "type": "boolean",
          "default": false
        },
        "回合数": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "环境侵蚀": {
          "type": "boolean",
          "default": false
        }
      },
      "required": ["当前场景", "当前世界", "关键NPC", "战斗状态", "回合数", "环境侵蚀"]
    },
    "当前世界": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string",
          "default": ""
        },
        "等级": {
          "enum": ["", "F级", "E级", "D级", "C级", "B级", "A级", "S级"],
          "default": ""
        },
        "类型": {
          "enum": ["", "恐怖", "科幻", "奇幻", "武侠", "仙侠", "末世", "其他"],
          "default": ""
        }
      },
      "required": ["名称", "等级", "类型"]
    },
    "NPC": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "关系": {
          "type": "string"
        },
        "状态": {
          "type": "string",
          "default": "存活"
        }
      },
      "required": ["名称", "关系", "状态"]
    },
    "战斗": {
      "type": "object",
      "properties": {
        "敌人": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/敌人"
          },
          "default": []
        },
        "战斗日志": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["敌人", "战斗日志"]
    },
    "敌人": {
      "type": "object",
      "properties": {
        "名称": {
          "type": "string"
        },
        "HP": {
          "type": "object",
          "properties": {
            "当前": {
              "type": "number"
            },
            "最大": {
              "type": "number"
            }
          },
          "required": ["当前", "最大"]
        },
        "状态": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["名称", "HP", "状态"]
    },
    "进度": {
      "type": "object",
      "properties": {
        "完成世界数": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "当前世界存活时间": {
          "type": "number",
          "default": 0
        },
        "总游戏时间": {
          "type": "number",
          "default": 0
        },
        "死亡次数": {
          "type": "number",
          "minimum": 0,
          "default": 0
        }
      },
      "required": ["完成世界数", "当前世界存活时间", "总游戏时间", "死亡次数"]
    }
  }
}
